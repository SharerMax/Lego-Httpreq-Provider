{
  "name": "lego-httpreq-provider",
  "type": "module",
  "version": "0.0.1",
  "description": "An httpreq DNS Provider of Lego ACME client",
  "author": "Author Name <author.name@mail.com>",
  "license": "MIT",
  "homepage": "https://github.com/author/library#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/author/library.git"
  },
  "bugs": {
    "url": "https://github.com/author/library/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.21.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --onSuccess \"node --env-file .env.local ./dist/index.mjs\"",
    "start": "node ./dist/index.mjs",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "@hono/standard-validator": "^0.2.2",
    "hono": "^4.12.22",
    "obug": "^2.1.1",
    "smol-toml": "^1.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^24.12.4",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
